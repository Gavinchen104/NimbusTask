# Local development (see README)
# If using docker compose (recommended): docker compose up -d
# Then use the DATABASE_URL / MONGODB_URI below as-is.

DATABASE_URL=postgresql://nimbus:nimbus@localhost:5433/nimbustask
MONGODB_URI=mongodb://localhost:27017/nimbustask
DEV_LOCAL_AUTH=true
MONGO_DB_NAME=nimbustask

