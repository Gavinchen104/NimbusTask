# Required: HTTP API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000

# Local API with X-Dev-User-* headers (matches apps/api dev server)
VITE_DEV_LOCAL_AUTH=true
VITE_DEV_USER_ID=dev-local-user
VITE_DEV_USER_EMAIL=dev@local.test

# AWS Cognito (deployed API) — leave blank when using dev auth above
# VITE_USER_POOL_ID=us-east-1_xxxx
# VITE_USER_POOL_CLIENT_ID=xxxx
